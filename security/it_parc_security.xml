<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Catégorie de module -->
        <record id="module_category_it_parc" model="ir.module.category">
            <field name="name">IT Parc</field>
            <field name="description">Gestion du parc informatique TECHPARK CI</field>
            <field name="sequence">50</field>
        </record>

        <!-- Groupe IT Technicien -->
        <record id="group_it_technicien" model="res.groups">
            <field name="name">IT Technicien</field>
            <field name="category_id" ref="module_category_it_parc"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Technicien IT : lecture du parc et création d'interventions</field>
        </record>

        <!-- Groupe IT Manager -->
        <record id="group_it_manager" model="res.groups">
            <field name="name">IT Manager</field>
            <field name="category_id" ref="module_category_it_parc"/>
            <field name="implied_ids" eval="[(4, ref('group_it_technicien'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Manager IT : accès complet au module it_parc</field>
        </record>

        <!-- Règle : technicien lecture seule sur les équipements -->
        <record id="rule_it_equipment_technicien" model="ir.rule">
            <field name="name">IT Parc: Équipements - Technicien lecture</field>
            <field name="model_id" ref="model_it_equipment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_technicien'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Règle : manager accès complet équipements -->
        <record id="rule_it_equipment_manager" model="ir.rule">
            <field name="name">IT Parc: Équipements - Manager complet</field>
            <field name="model_id" ref="model_it_equipment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Règle : technicien peut créer/modifier ses interventions -->
        <record id="rule_it_intervention_technicien" model="ir.rule">
            <field name="name">IT Parc: Interventions - Technicien</field>
            <field name="model_id" ref="model_it_intervention"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_technicien'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Règle : manager accès complet interventions -->
        <record id="rule_it_intervention_manager" model="ir.rule">
            <field name="name">IT Parc: Interventions - Manager complet</field>
            <field name="model_id" ref="model_it_intervention"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Règle : technicien lecture seule contrats et alertes -->
        <record id="rule_it_contract_technicien" model="ir.rule">
            <field name="name">IT Parc: Contrats - Technicien lecture</field>
            <field name="model_id" ref="model_it_contract"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_technicien'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_it_alerte_technicien" model="ir.rule">
            <field name="name">IT Parc: Alertes - Technicien lecture</field>
            <field name="model_id" ref="model_it_alerte"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_technicien'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_it_assignment_technicien" model="ir.rule">
            <field name="name">IT Parc: Affectations - Technicien lecture</field>
            <field name="model_id" ref="model_it_assignment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_technicien'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_it_contract_manager" model="ir.rule">
            <field name="name">IT Parc: Contrats - Manager complet</field>
            <field name="model_id" ref="model_it_contract"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_it_alerte_manager" model="ir.rule">
            <field name="name">IT Parc: Alertes - Manager complet</field>
            <field name="model_id" ref="model_it_alerte"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_it_assignment_manager" model="ir.rule">
            <field name="name">IT Parc: Affectations - Manager complet</field>
            <field name="model_id" ref="model_it_assignment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>

        <!-- Catégories d'équipement -->
        <record id="category_pc" model="it.equipment.category">
            <field name="name">Ordinateur Portable</field>
            <field name="description">PC portables pour les employés</field>
        </record>
        <record id="category_desktop" model="it.equipment.category">
            <field name="name">Ordinateur de Bureau</field>
            <field name="description">PC de bureau fixes</field>
        </record>
        <record id="category_server" model="it.equipment.category">
            <field name="name">Serveur</field>
            <field name="description">Serveurs informatiques</field>
        </record>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <menuitem id="menu_it_assignment" name="Affectations"
                  parent="menu_it_parc_root" sequence="2"
                  groups="it_parc.group_it_technicien"/>

        <record id="action_it_assignment" model="ir.actions.act_window">
            <field name="name">Affectations</field>
            <field name="res_model">it.assignment</field>
            <field name="view_mode">list,form</field>
            <field name="groups_id" eval="[(4, ref('group_it_technicien'))]"/>
        </record>

        <menuitem id="menu_it_assignment_action" name="Toutes les affectations"
                  parent="menu_it_assignment" action="action_it_assignment"
                  groups="it_parc.group_it_technicien" sequence="1"/>

        <record id="view_it_assignment_tree" model="ir.ui.view">
            <field name="name">it.assignment.list</field>
            <field name="model">it.assignment</field>
            <field name="arch" type="xml">
                <list string="Affectations" decoration-success="state == 'active'"
                      decoration-muted="state == 'returned'">
                    <field name="equipment_id"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="state" widget="badge"/>
                </list>
            </field>
        </record>

        <record id="view_it_assignment_form" model="ir.ui.view">
            <field name="name">it.assignment.form</field>
            <field name="model">it.assignment</field>
            <field name="arch" type="xml">
                <form string="Affectation">
                    <header>
                        <button name="action_reassign" string="Réaffecter" type="object"
                                class="btn-primary" invisible="state != 'active'"
                                groups="it_parc.group_it_manager"/>
                        <button name="action_return" string="Retourner" type="object"
                                invisible="state != 'active'"
                                groups="it_parc.group_it_manager"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Équipement">
                                <field name="equipment_id"/>
                                <field name="employee_id"/>
                                <field name="department_id"/>
                            </group>
                            <group string="Période">
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Historique des réaffectations">
                                <field name="transfer_history_ids">
                                    <list>
                                        <field name="date"/>
                                        <field name="from_employee_id"/>
                                        <field name="to_employee_id"/>
                                        <field name="from_department_id"/>
                                        <field name="to_department_id"/>
                                        <field name="reason"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_it_assignment_search" model="ir.ui.view">
            <field name="name">it.assignment.search</field>
            <field name="model">it.assignment</field>
            <field name="arch" type="xml">
                <search string="Rechercher affectations">
                    <field name="equipment_id"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <filter string="Active" name="filter_active" domain="[('state', '=', 'active')]"/>
                    <filter string="Retournée" name="filter_returned" domain="[('state', '=', 'returned')]"/>
                    <group expand="0" string="Regrouper par">
                        <filter string="Département" name="group_department" context="{'group_by': 'department_id'}"/>
                        <filter string="Employé" name="group_employee" context="{'group_by': 'employee_id'}"/>
                        <filter string="État" name="group_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>

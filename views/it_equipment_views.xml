<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Menu racine -->
        <menuitem id="menu_it_parc_root" name="IT Parc"
                  web_icon="it_parc,static/description/icon.png"
                  groups="it_parc.group_it_technicien"
                  sequence="10"/>

        <!-- Équipements -->
        <menuitem id="menu_it_equipment" name="Équipements"
                  parent="menu_it_parc_root" sequence="1"/>

        <record id="action_it_equipment" model="ir.actions.act_window">
            <field name="name">Équipements</field>
            <field name="res_model">it.equipment</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="groups_id" eval="[(4, ref('group_it_technicien'))]"/>
            <field name="context">{'search_default_filter_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Enregistrez votre premier équipement IT
                </p>
                <p>Gérez l'inventaire complet du parc informatique TECHPARK CI.</p>
            </field>
        </record>

        <menuitem id="menu_it_equipment_action" name="Tous les équipements"
                  parent="menu_it_equipment" action="action_it_equipment"
                  groups="it_parc.group_it_technicien" sequence="1"/>

        <!-- Kanban -->
        <record id="view_it_equipment_kanban" model="ir.ui.view">
            <field name="name">it.equipment.kanban</field>
            <field name="model">it.equipment</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="brand"/>
                    <field name="model"/>
                    <field name="state"/>
                    <field name="department_id"/>
                    <field name="warranty_end_date"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top mb-2">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'draft': 'info', 'assigned': 'success', 'maintenance': 'warning', 'retired': 'danger'}}"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="category_id"/>
                                    <div t-if="record.brand.raw_value">
                                        <i class="fa fa-tag" title="Marque"/> <field name="brand"/> <field name="model"/>
                                    </div>
                                    <div t-if="record.department_id.raw_value">
                                        <i class="fa fa-building" title="Département"/> <field name="department_id"/>
                                    </div>
                                    <div t-if="record.warranty_end_date.raw_value" class="text-muted">
                                        <i class="fa fa-shield" title="Garantie"/> Garantie : <field name="warranty_end_date"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- List -->
        <record id="view_it_equipment_tree" model="ir.ui.view">
            <field name="name">it.equipment.list</field>
            <field name="model">it.equipment</field>
            <field name="arch" type="xml">
                <list string="Équipements" decoration-muted="state == 'retired'"
                      decoration-warning="state == 'maintenance'" decoration-success="state == 'assigned'">
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="brand"/>
                    <field name="model"/>
                    <field name="department_id"/>
                    <field name="location"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'draft'"
                           decoration-success="state == 'assigned'"
                           decoration-warning="state == 'maintenance'"
                           decoration-danger="state == 'retired'"/>
                    <field name="warranty_end_date"/>
                    <field name="purchase_price" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Form -->
        <record id="view_it_equipment_form" model="ir.ui.view">
            <field name="name">it.equipment.form</field>
            <field name="model">it.equipment</field>
            <field name="arch" type="xml">
                <form string="Équipement">
                    <header>
                        <button name="action_assign" string="Affecter" type="object"
                                class="btn-primary" invisible="state not in ('draft',)"
                                groups="it_parc.group_it_manager"/>
                        <button name="action_reassign" string="Réaffecter" type="object"
                                class="btn-primary" invisible="state != 'assigned'"
                                groups="it_parc.group_it_manager"/>
                        <button name="action_return" string="Retourner" type="object"
                                invisible="state != 'assigned'"
                                groups="it_parc.group_it_manager"/>
                        <button name="action_set_maintenance" string="Mettre en maintenance" type="object"
                                invisible="state not in ('draft', 'assigned')"
                                groups="it_parc.group_it_manager"/>
                        <button name="action_retire" string="Mettre au rebut" type="object"
                                class="btn-secondary" invisible="state == 'retired'"
                                groups="it_parc.group_it_manager"
                                confirm="Confirmer la mise au rebut de cet équipement ?"/>
                        <button name="action_print_equipment_card" string="Imprimer fiche PDF" type="object"
                                class="btn-secondary"/>
                        <button name="action_export_inventory_excel" string="Export Excel inventaire" type="object"
                                class="btn-secondary" groups="it_parc.group_it_manager"/>
                        <button name="action_print_inventory_report" string="Rapport inventaire PDF" type="object"
                                class="btn-secondary"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,assigned,maintenance,retired"/>
                    </header>
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="Numéro de série / identifiant"/></h1>
                        </div>
                        <group>
                            <group string="Identification">
                                <field name="category_id"/>
                                <field name="brand"/>
                                <field name="model"/>
                                <field name="location"/>
                            </group>
                            <group string="Achat &amp; Garantie">
                                <field name="purchase_date"/>
                                <field name="warranty_end_date"/>
                                <field name="purchase_price"/>
                                <field name="department_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Affectations" name="assignments">
                                <field name="assignment_ids">
                                    <list>
                                        <field name="employee_id"/>
                                        <field name="department_id"/>
                                        <field name="date_start"/>
                                        <field name="date_end"/>
                                        <field name="state" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Interventions" name="interventions">
                                <field name="intervention_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="technician_id"/>
                                        <field name="type"/>
                                        <field name="date_start"/>
                                        <field name="cost"/>
                                        <field name="state" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Contrats" name="contracts">
                                <field name="contract_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="supplier_id"/>
                                        <field name="type"/>
                                        <field name="end_date"/>
                                        <field name="days_remaining"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes" name="notes">
                                <field name="notes" placeholder="Notes complémentaires..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search -->
        <record id="view_it_equipment_search" model="ir.ui.view">
            <field name="name">it.equipment.search</field>
            <field name="model">it.equipment</field>
            <field name="arch" type="xml">
                <search string="Rechercher équipements">
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="brand"/>
                    <field name="model"/>
                    <field name="department_id"/>
                    <field name="location"/>
                    <filter string="Actifs (hors rebut)" name="filter_active" domain="[('state', '!=', 'retired')]"/>
                    <filter string="Brouillon" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Affecté" name="filter_assigned" domain="[('state', '=', 'assigned')]"/>
                    <filter string="En maintenance" name="filter_maintenance" domain="[('state', '=', 'maintenance')]"/>
                    <filter string="Garantie renseignée" name="filter_warranty"
                            domain="[('warranty_end_date', '!=', False)]"/>
                    <separator/>
                    <group expand="0" string="Regrouper par">
                        <filter string="Catégorie" name="group_category" context="{'group_by': 'category_id'}"/>
                        <filter string="Département" name="group_department" context="{'group_by': 'department_id'}"/>
                        <filter string="État" name="group_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Catégories -->
        <record id="action_it_equipment_category" model="ir.actions.act_window">
            <field name="name">Catégories d'équipement</field>
            <field name="res_model">it.equipment.category</field>
            <field name="view_mode">list,form</field>
            <field name="groups_id" eval="[(4, ref('group_it_manager'))]"/>
        </record>

        <menuitem id="menu_it_equipment_category" name="Catégories"
                  parent="menu_it_equipment" action="action_it_equipment_category"
                  groups="it_parc.group_it_manager" sequence="2"/>

        <record id="view_it_equipment_category_tree" model="ir.ui.view">
            <field name="name">it.equipment.category.list</field>
            <field name="model">it.equipment.category</field>
            <field name="arch" type="xml">
                <list string="Catégories">
                    <field name="name"/>
                    <field name="description"/>
                </list>
            </field>
        </record>

        <record id="view_it_equipment_category_form" model="ir.ui.view">
            <field name="name">it.equipment.category.form</field>
            <field name="model">it.equipment.category</field>
            <field name="arch" type="xml">
                <form string="Catégorie">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>

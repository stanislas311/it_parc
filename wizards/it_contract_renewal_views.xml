<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard Renouvellement Contrat -->
        <record id="view_it_contract_renewal_form" model="ir.ui.view">
            <field name="name">it.contract.renewal.form</field>
            <field name="model">it.contract.renewal</field>
            <field name="arch" type="xml">
                <form string="Renouvellement de contrat">
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="new_end_date"/>
                            <field name="new_amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <footer>
                        <button name="action_renew" string="Renouveler" type="object" class="btn-primary"/>
                        <button string="Annuler" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
